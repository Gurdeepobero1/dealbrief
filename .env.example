# ============================================================
# DealBrief — Environment Variables
# Copy this file to .env and fill in real values.
# ============================================================

# ---- LLM Providers (all free tier) ------------------------------------------
# Get at https://console.groq.com (no credit card required)
GROQ_API_KEY=

# Get at https://openrouter.ai/keys (free models available)
OPENROUTER_API_KEY=

# Optional: paid fallback for production
# ANTHROPIC_API_KEY=

# ---- Data Sources -----------------------------------------------------------
# Proxycurl — LinkedIn public profile data (licensed)
# https://nubela.co/proxycurl — pay-per-call
PROXYCURL_API_KEY=

# Exa.ai — semantic web search
# https://exa.ai — free tier 1,000 searches/month
EXA_API_KEY=

# Listen Notes — podcast search
# https://listennotes.com/api — free tier
LISTEN_NOTES_API_KEY=

# BuiltWith — tech stack
# https://builtwith.com/api — free tier
BUILTWITH_API_KEY=

# GitHub — free, rate-limited without auth
# Personal access token raises limits. https://github.com/settings/tokens
GITHUB_TOKEN=

# Crunchbase — funding data
# https://data.crunchbase.com — paid
CRUNCHBASE_API_KEY=

# ---- App Config -------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# Cache TTL for enrichment results (seconds). 7 days = 604800.
CACHE_TTL_SECONDS=604800

# Hard confidence floor. Claims below this are not surfaced.
MIN_CONFIDENCE=0.4
